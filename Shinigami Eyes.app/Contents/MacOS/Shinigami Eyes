#!/bin/bash
# Shinigami Eyes — launcher
# Finds python3 with tkinter and runs the app from Resources.

SCRIPT_DIR="$(cd "$(dirname "$0")/../Resources" && pwd)"
SCRIPT="$SCRIPT_DIR/nas_migrate_gui.py"

# Try Homebrew python first (includes tkinter), then system python3
for PY in \
    /opt/homebrew/bin/python3 \
    /usr/local/bin/python3 \
    /usr/bin/python3 \
    python3
do
    if command -v "$PY" &>/dev/null; then
        # Check tkinter is available
        if "$PY" -c "import tkinter" 2>/dev/null; then
            exec "$PY" "$SCRIPT"
        fi
    fi
done

osascript -e 'display alert "Shinigami Eyes" message "Python 3 with tkinter not found.\n\nInstall it with:\n  brew install python\n\nor:\n  brew install python-tk" as warning'
exit 1
